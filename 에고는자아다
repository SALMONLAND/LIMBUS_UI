namespace EgoGiftInjector
{
    [BepInPlugin("com.mod.egogiftinjector", "EgoGiftInjector", "1.7.0")]
    public class EgoGiftInjectorPlugin : BasePlugin
    {
        internal static new ManualLogSource? Log;

        internal static System.Collections.Generic.List<(int id, int tier)> AutoInjectList
            = new System.Collections.Generic.List<(int id, int tier)>();

        public override void Load()
        {
            Log = base.Log;
            Log.LogInfo("step 1 - load start");

            try
            {
                var harmony  = new Harmony("com.mod.egogiftinjector");
                var dpmType  = typeof(EgoGiftManager).Assembly.GetType("Dungeon.DungeonProgressManager");
                var postfix  = new HarmonyMethod(typeof(DungeonPatches)
                                   .GetMethod("Postfix", BindingFlags.Public | BindingFlags.Static));

                harmony.Patch(
                    dpmType.GetMethod("EnterDungeon",
                        BindingFlags.Public | BindingFlags.Static),
                    postfix: postfix);

                harmony.Patch(
                    dpmType.GetMethod("ReloadByServerData",
                        BindingFlags.Public | BindingFlags.Static),
                    postfix: postfix);

                Log.LogInfo("step 2 - harmony patched");
            }
            catch (Exception ex)
            {
                Log.LogError("step 2 - harmony failed: " + ex.Message);
            }

            AddComponent<InjectorUI>();
            Log.LogInfo("step 3 - component added");
        }
    }

    // ── Harmony 패치 ──────────────────────────────────────────

    public static class DungeonPatches
    {
        public static void Postfix()
        {
            try
            {
                if (EgoGiftInjectorPlugin.AutoInjectList.Count == 0) return;

                var dpmType = typeof(EgoGiftManager).Assembly.GetType("Dungeon.DungeonProgressManager");
                var mgr     = dpmType.GetMethod("GetEgoGiftManager",
                                  BindingFlags.Public | BindingFlags.Static)
                                  .Invoke(null, null) as EgoGiftManager;
                if (mgr == null) return;

                var lapType  = typeof(EgoGiftManager).Assembly.GetType("LAPNACHCMCD");
                var lapCtor  = lapType.GetConstructor(new System.Type[] { typeof(int) });
                var mapCtor  = typeof(DungeonMapEgoGift).GetConstructor(
                                   new System.Type[] { lapType, typeof(int) });
                var setMethod    = typeof(EgoGiftManager).GetMethod("SetEgoGiftList",
                                   BindingFlags.Public | BindingFlags.Instance);
                var updateMethod = typeof(EgoGiftManager).GetMethod("OnUpdateEgoGift",
                                   BindingFlags.Public | BindingFlags.Instance,
                                   null, System.Type.EmptyTypes, null);

                var existing = mgr.GetAcquiredEgoGiftList();
                var mapList  = new List<DungeonMapEgoGift>();
                foreach (var g in existing)
                    mapList.Add(new DungeonMapEgoGift(g));

                int added = 0;
                foreach (var (id, tier) in EgoGiftInjectorPlugin.AutoInjectList)
                {
                    bool already = false;
                    foreach (var g in existing)
                        if (g.EgoGiftID == id) { already = true; break; }
                    if (already) continue;

                    var lap     = lapCtor.Invoke(new object[] { id });
                    var mapGift = (DungeonMapEgoGift)mapCtor.Invoke(new object[] { lap, tier });
                    mapList.Add(mapGift);
                    added++;
                }

                if (added == 0) return;
                setMethod.Invoke(mgr, new object[] { mapList, true });
                updateMethod?.Invoke(mgr, null);
                EgoGiftInjectorPlugin.Log?.LogInfo($"자동 주입 완료: {added}개 추가");
            }
            catch (Exception ex)
            {
                EgoGiftInjectorPlugin.Log?.LogError($"자동 주입 오류: {ex.Message}");
            }
        }
    }

