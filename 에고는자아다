// - Harmony PatchAll() 제거, 수동 패치로 변경
// - UI: ver.1.4에서 동작했던 GUI.Box + GUILayout.BeginArea 방식 복원

using BepInEx;
using BepInEx.Unity.IL2CPP;
using BepInEx.Logging;
using HarmonyLib;
using UnityEngine;
using Il2CppSystem.Collections.Generic;
using System;
using System.Reflection;
